{
  "name": "mini-step",
  "version": "0.1.0",
  "description": "Tiny declarative state machines over discriminated unions — per-state typed data, shared transition groups, async as states + effects. Zero dependencies.",
  "keywords": [
    "state-machine",
    "fsm",
    "finite-state-machine",
    "discriminated-union",
    "typescript",
    "react",
    "reducer"
  ],
  "license": "MIT",
  "author": "Peter Scott",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/peterscottsa/mini-step.git"
  },
  "type": "module",
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "typesVersions": {
    "*": {
      "react": [
        "./dist/react.d.cts"
      ]
    }
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./react": {
      "import": {
        "types": "./dist/react.d.mts",
        "default": "./dist/react.mjs"
      },
      "require": {
        "types": "./dist/react.d.cts",
        "default": "./dist/react.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint:pkg": "publint && attw --pack .",
    "check": "npm run typecheck && npm run test && npm run build && npm run lint:pkg",
    "prepublishOnly": "npm run check"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.5",
    "@changesets/cli": "^2.31.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "jsdom": "^29.1.1",
    "publint": "^0.3.21",
    "react": "^19.2.7",
    "tsdown": "^0.22.9",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10",
    "zod": "^4.4.3"
  }
}
